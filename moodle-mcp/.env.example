# Copy to .env and fill in. NEVER commit the real token.

# Base URL of your Moodle site (no trailing slash).
MOODLE_URL=https://moodle.example.edu

# Web service token generated in Moodle (Site admin > Server > Web services > Manage tokens).
MOODLE_TOKEN=your_token_here

# Set to exactly "true" to enable write tools (course/user/activity creation,
# enrolment, file upload). Any other value = read-only.
MOODLE_ALLOW_WRITE=false
